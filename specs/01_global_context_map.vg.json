{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 650,
  "height": 420,
  "title": "Malaysia in Southeast Asian context",
  "projection": {
    "type": "mercator",
    "center": [
      108,
      5
    ],
    "scale": 850
  },
  "layer": [
    {
      "data": {
        "url": "https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json",
        "format": {
          "type": "topojson",
          "feature": "countries"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#eadfce",
        "stroke": "#ffffff",
        "strokeWidth": 0.8
      }
    },
    {
      "data": {
        "url": "../data/asean_meat_context.csv",
        "format": {
          "type": "csv"
        }
      },
      "mark": {
        "type": "circle",
        "size": 220,
        "opacity": 0.85,
        "stroke": "#2b2118",
        "strokeWidth": 1
      },
      "encoding": {
        "longitude": {
          "field": "longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "latitude",
          "type": "quantitative"
        },
        "color": {
          "field": "focus_type",
          "type": "nominal",
          "title": "Map role",
          "scale": {
            "domain": [
              "Malaysia focus",
              "Regional context"
            ],
            "range": [
              "#e6a23c",
              "#8b3a2e"
            ]
          }
        },
        "tooltip": [
          {
            "field": "country",
            "type": "nominal",
            "title": "Country"
          },
          {
            "field": "note",
            "type": "nominal",
            "title": "Note"
          },
          {
            "field": "malaysia_total_pcc_2024",
            "type": "quantitative",
            "title": "Malaysia total meat PCC 2024 (kg/person/year)",
            "format": ".2f"
          }
        ]
      }
    },
    {
      "data": {
        "url": "../data/asean_meat_context.csv",
        "format": {
          "type": "csv"
        }
      },
      "transform": [
        {
          "filter": "datum.country == 'Malaysia'"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 14,
        "fontSize": 14,
        "fontWeight": "bold",
        "color": "#2b2118"
      },
      "encoding": {
        "longitude": {
          "field": "longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "latitude",
          "type": "quantitative"
        },
        "text": {
          "value": "Malaysia: 80.49 kg/person/year (2024)"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "legend": {
      "orient": "bottom"
    }
  }
}