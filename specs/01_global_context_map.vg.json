{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 650,
  "height": 420,
  "title": "Malaysia's meat consumption in Southeast Asian context",
  "projection": {
    "type": "mercator",
    "center": [108, 5],
    "scale": 850
  },
  "layer": [
    {
      "data": {
        "url": "https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json",
        "format": {
          "type": "topojson",
          "feature": "countries"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#eadfce",
        "stroke": "#ffffff",
        "strokeWidth": 0.8
      }
    },
    {
      "data": {
        "url": "../data/asean_meat_context.csv",
        "format": {
          "type": "csv"
        }
      },
      "mark": {
        "type": "circle",
        "opacity": 0.85,
        "stroke": "#2b2118",
        "strokeWidth": 1
      },
      "encoding": {
        "longitude": {
          "field": "longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "latitude",
          "type": "quantitative"
        },
        "size": {
          "field": "consumption_kg_per_person",
          "type": "quantitative",
          "title": "kg/person/year",
          "scale": {
            "domain": [0, 100],
            "range": [80, 1200]
          }
        },
        "color": {
          "condition": {
            "test": "datum.country == 'Malaysia'",
            "value": "#e6a23c"
          },
          "value": "#8b3a2e"
        },
        "tooltip": [
          {
            "field": "country",
            "type": "nominal",
            "title": "Country"
          },
          {
            "field": "consumption_kg_per_person",
            "type": "quantitative",
            "title": "Meat consumption, kg/person/year",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "data": {
        "url": "../data/asean_meat_context.csv",
        "format": {
          "type": "csv"
        }
      },
      "transform": [
        {
          "filter": "datum.country == 'Malaysia'"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 14,
        "fontSize": 14,
        "fontWeight": "bold",
        "color": "#2b2118"
      },
      "encoding": {
        "longitude": {
          "field": "longitude",
          "type": "quantitative"
        },
        "latitude": {
          "field": "latitude",
          "type": "quantitative"
        },
        "text": {
          "value": "Malaysia"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "legend": {
      "orient": "bottom"
    }
  }
}