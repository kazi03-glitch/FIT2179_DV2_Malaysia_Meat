{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 650,
  "height": 280,
  "title": "Self-sufficiency ratio compared with the 100% domestic supply target",
  "data": {
    "url": "../data/meat_ssr_long.csv",
    "format": {
      "type": "csv"
    }
  },
  "transform": [
    {
      "filter": "datum.year == 2024"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 4
      },
      "encoding": {
        "x": {
          "field": "ssr_percent",
          "type": "quantitative",
          "title": "Self-sufficiency ratio (%)",
          "scale": {
            "domain": [0, 120]
          }
        },
        "y": {
          "field": "meat_type",
          "type": "nominal",
          "sort": ["Poultry", "Pork", "Beef", "Mutton"],
          "title": null
        },
        "color": {
          "field": "meat_type",
          "type": "nominal",
          "scale": {
            "domain": ["Poultry", "Beef", "Mutton", "Pork"],
            "range": ["#e6a23c", "#8b3a2e", "#7a4ea3", "#d67c8c"]
          },
          "legend": null
        },
        "tooltip": [
          {
            "field": "meat_type",
            "type": "nominal",
            "title": "Meat type"
          },
          {
            "field": "ssr_percent",
            "type": "quantitative",
            "title": "SSR (%)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "rule",
        "color": "#2b2118",
        "strokeDash": [6, 4],
        "strokeWidth": 2
      },
      "encoding": {
        "x": {
          "datum": 100
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "bottom",
        "dx": 6,
        "dy": -8,
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#2b2118"
      },
      "encoding": {
        "x": {
          "datum": 100
        },
        "y": {
          "datum": "Poultry"
        },
        "text": {
          "value": "100% target"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "grid": true,
      "gridOpacity": 0.2
    }
  }
}