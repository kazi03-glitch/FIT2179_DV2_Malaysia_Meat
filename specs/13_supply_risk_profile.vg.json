{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 650,
  "height": 300,
  "title": "Supply risk profile by meat type, derived from 2024 official data",
  "data": {
    "url": "../data/meat_risk_profile.csv",
    "format": {
      "type": "csv"
    }
  },
  "layer": [
    {
      "mark": {
        "type": "rect",
        "cornerRadius": 4
      },
      "encoding": {
        "x": {
          "field": "indicator",
          "type": "nominal",
          "title": null,
          "sort": [
            "Consumption level",
            "Domestic supply strength",
            "Import dependency",
            "Supply risk"
          ],
          "axis": {
            "labelAngle": 0,
            "labelLimit": 120
          }
        },
        "y": {
          "field": "meat_type",
          "type": "nominal",
          "title": null,
          "sort": [
            "Poultry",
            "Pork",
            "Beef",
            "Mutton"
          ]
        },
        "color": {
          "field": "score",
          "type": "quantitative",
          "title": "Score",
          "scale": {
            "domain": [
              0,
              100
            ],
            "scheme": "oranges"
          }
        },
        "tooltip": [
          {
            "field": "meat_type",
            "type": "nominal",
            "title": "Meat type"
          },
          {
            "field": "indicator",
            "type": "nominal",
            "title": "Indicator"
          },
          {
            "field": "score",
            "type": "quantitative",
            "title": "Score",
            "format": ".0f"
          },
          {
            "field": "data_status",
            "type": "nominal",
            "title": "Status"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "fontSize": 13,
        "fontWeight": "bold",
        "color": "#2b2118"
      },
      "encoding": {
        "x": {
          "field": "indicator",
          "type": "nominal",
          "sort": [
            "Consumption level",
            "Domestic supply strength",
            "Import dependency",
            "Supply risk"
          ]
        },
        "y": {
          "field": "meat_type",
          "type": "nominal",
          "sort": [
            "Poultry",
            "Pork",
            "Beef",
            "Mutton"
          ]
        },
        "text": {
          "field": "score",
          "type": "quantitative",
          "format": ".0f"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "grid": false
    },
    "legend": {
      "orient": "bottom"
    }
  }
}