{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 650,
  "height": 320,
  "title": "Import and export volume by meat type in 2024",
  "data": {
    "url": "data/meat_trade_long.csv",
    "format": {
      "type": "csv"
    }
  },
  "transform": [
    {
      "calculate": "datum.trade_type == 'Import' ? datum.value_tonnes : -datum.value_tonnes",
      "as": "signed_value"
    }
  ],
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 3
  },
  "encoding": {
    "x": {
      "field": "signed_value",
      "type": "quantitative",
      "title": "Trade volume, tonnes",
      "axis": {
        "format": ".2s"
      }
    },
    "y": {
      "field": "meat_type",
      "type": "nominal",
      "title": null,
      "sort": [
        "Poultry",
        "Pork",
        "Beef",
        "Mutton"
      ]
    },
    "color": {
      "field": "trade_type",
      "type": "nominal",
      "title": "Trade type",
      "scale": {
        "domain": [
          "Import",
          "Export"
        ],
        "range": [
          "#c85c3d",
          "#4c8c6b"
        ]
      }
    },
    "tooltip": [
      {
        "field": "meat_type",
        "type": "nominal",
        "title": "Meat type"
      },
      {
        "field": "trade_type",
        "type": "nominal",
        "title": "Trade type"
      },
      {
        "field": "value_tonnes",
        "type": "quantitative",
        "title": "Volume, tonnes",
        "format": ","
      },
      {
        "field": "data_status",
        "type": "nominal",
        "title": "Status"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "grid": true,
      "gridOpacity": 0.2
    }
  }
}